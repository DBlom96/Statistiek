\newcommand{\binomial}[2]{\textrm{Binomiaal}(#1, #2)} % Binomiale verdeling
\newcommand{\poisson}[1]{\textrm{Poisson}(#1)} % Poisson verdeling
\newcommand{\exponential}[1]{\textrm{Exponentieel}(#1)} % Exponentiele verdeling

